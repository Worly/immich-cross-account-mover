# Two API keys, one per account (Immich -> Account Settings -> API Keys).
# Simplest: grant "all" permissions on each key. For least privilege:
#   SOURCE (account A): album.read, asset.read, asset.view, asset.download, asset.delete
#   DEST   (account B): album.read, asset.read, asset.upload, albumAsset.create
# The service does NOT need the user.read permission.
IMMICH_API_KEY_SOURCE=replace-with-account-A-key
IMMICH_API_KEY_DEST=replace-with-account-B-key
